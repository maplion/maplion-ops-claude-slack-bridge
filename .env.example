# Slack bot token (xoxb-...) from https://api.slack.com/apps -> OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...

# Slack app-level token (xapp-...) with connections:write scope
# from https://api.slack.com/apps -> Basic Information -> App-Level Tokens
SLACK_APP_TOKEN=xapp-...

# OPTIONAL — Anthropic API key (pay-as-you-go billing).
# Leave UNSET to use your Claude Pro/Max subscription instead. The bridge spawns
# the Claude Code CLI, which falls back to OAuth tokens in ~/.claude/ when this
# env var is missing. Just don't set it (or comment it out).
# ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — override the model. Defaults to claude-sonnet-4-6.
# CLAUDE_MODEL=claude-sonnet-4-6

# OPTIONAL — minutes of inactivity before a thread session is closed. Default 30.
# IDLE_TIMEOUT_MIN=30
